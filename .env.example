# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LLM (Alibaba Cloud Bailian / OpenAI-compatible)
LLM_API_KEY=your-llm-api-key
LLM_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_PROVIDER=openai-compatible

# Redis (Worker)
REDIS_URL=redis://localhost:6379

# Worker HTTP proxy (for endpoints that need DashScope access from overseas Vercel)
WORKER_URL=https://your-worker.up.railway.app
WORKER_SHARED_SECRET=change-me-shared-with-worker

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_MAX_PRICE_ID=price_...
