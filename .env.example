# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LLM fallback chain — same shape as worker/.env.example. Next.js only reads
# these for local recommend/preview flows; the production worker on Railway
# owns the real chain. Users with BYOK save a chain via /settings/llm instead,
# which overrides these env defaults per-request.
#
# Up to 10 entries (LLM_1_* through LLM_10_*). Each group:
#   LLM_N_PROVIDER       openai_compatible | anthropic | google
#   LLM_N_API_KEY        required
#   LLM_N_MODEL          required
#   LLM_N_BASE_URL       required for openai_compatible
#   LLM_N_VISION_MODEL   optional
#   LLM_N_LABEL          optional

LLM_1_PROVIDER=openai_compatible
LLM_1_API_KEY=your-dashscope-key
LLM_1_MODEL=glm-5
LLM_1_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_1_VISION_MODEL=qwen3.5-omni-plus

# Encryption secret for BYOK API keys saved via /settings/llm. Any string
# ≥16 chars; SHA-256 is applied internally. Generate: openssl rand -base64 32
LLM_KEY_ENCRYPTION_SECRET=

# Redis (Worker)
REDIS_URL=redis://localhost:6379

# Worker HTTP proxy (for endpoints that need DashScope access from overseas Vercel)
WORKER_URL=https://your-worker.up.railway.app
WORKER_SHARED_SECRET=change-me-shared-with-worker

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_MAX_PRICE_ID=price_...

# Admin panel — comma-separated emails allowed to access /admin
# Empty = no one can access (deny by default)
ADMIN_EMAILS=
