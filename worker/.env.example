# Supabase (service role for worker)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM fallback chain — each numbered group is one entry. The worker tries
# entries in order (LLM_1_* → LLM_2_* → ...) until one succeeds. Permanent
# failures (401/403/404/quota) block that entry for the rest of the session.
#
# Up to 10 entries (LLM_1_* through LLM_10_*). You can mix providers freely:
# openai_compatible (needs BASE_URL), anthropic, google.
#
# Per-entry keys:
#   LLM_N_PROVIDER       openai_compatible | anthropic | google  (default: openai_compatible)
#   LLM_N_API_KEY        required
#   LLM_N_MODEL          required
#   LLM_N_BASE_URL       required for openai_compatible
#   LLM_N_VISION_MODEL   optional — model used for image/video recommend jobs
#   LLM_N_LABEL          optional — human-readable tag for logs

# Entry 1: GLM on Aliyun DashScope (primary)
LLM_1_PROVIDER=openai_compatible
LLM_1_API_KEY=your-dashscope-key
LLM_1_MODEL=glm-5
LLM_1_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_1_LABEL=glm-primary

# Entry 2: Qwen on the same DashScope key (fallback)
LLM_2_PROVIDER=openai_compatible
LLM_2_API_KEY=your-dashscope-key
LLM_2_MODEL=qwen3.6-plus
LLM_2_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_2_VISION_MODEL=qwen3.5-omni-plus
LLM_2_LABEL=qwen-fallback

# Entry 3: Claude as last-resort
# LLM_3_PROVIDER=anthropic
# LLM_3_API_KEY=sk-ant-...
# LLM_3_MODEL=claude-sonnet-4-6
# LLM_3_VISION_MODEL=claude-sonnet-4-6

# Hard cap on one LLM HTTP call (milliseconds). Slow/hung providers are aborted
# and the chain advances to the next entry.
LLM_TIMEOUT_MS=120000

# Legacy single-model env (kept for backwards-compat; ignored if any LLM_N_* is set):
# LLM_API_KEY=your-llm-api-key
# LLM_MODEL=glm-5
# LLM_VISION_MODEL=qwen3.5-omni-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_FALLBACK_MODELS=qwen3.6-plus,qwen3-32b

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# HTTP proxy server (receives recommend requests from Vercel)
PORT=8080
WORKER_SHARED_SECRET=change-me-shared-with-vercel
